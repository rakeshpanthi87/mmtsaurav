# ── Server ──────────────────────────────
PORT=3000
NODE_ENV=production

# ── Auth ────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_THIS_generate_a_64_char_random_hex_string
JWT_EXPIRES_IN=7d

# ── AI — Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY
AI_MODEL=claude-sonnet-4-20250514

# ── AI — OpenRouter (secondary, cost-optimised) ─────────────────
OPENROUTER_API_KEY=sk-or-REPLACE_WITH_YOUR_KEY
OR_MODEL_CATEGORISE=mistralai/mistral-7b-instruct:free
OR_MODEL_FACTCHECK=google/gemini-flash-1.5
OR_MODEL_ANALYSIS=anthropic/claude-3-haiku
OR_MODEL_FALLBACK=anthropic/claude-3-haiku

# ── News APIs ────────────────────────────────────────────────────
GNEWS_API_KEY=REPLACE_WITH_YOUR_KEY
PINEWS_API_KEY=REPLACE_WITH_YOUR_KEY
PINEWS_ENDPOINT=https://api.apinews.net/news

# ── Scraper ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SCRAPER_SECRET=CHANGE_THIS_generate_a_random_string

# ── App URLs ─────────────────────────────────────────────────────
APP_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
DB_PATH=./database/mmt.db

# ── Admin seed (change immediately after first deploy) ───────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_THIS_strong_password
ADMIN_NAME=Admin
